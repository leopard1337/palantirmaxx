{
  "name": "quantis-cli",
  "version": "0.1.0",
  "description": "Quantis data layer for agents – fetch intel, markets, feed as JSON",
  "type": "module",
  "bin": {
    "quantis": "./dist/index.js"
  },
  "files": ["dist"],
  "scripts": {
