{
  "name": "quantis-cli",
  "version": "0.1.0",
  "description": "Quantis data layer for agents – fetch intel, markets, feed as JSON",
  "type": "module",
  "bin": {
    "quantis-cli": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/leopard1337/palantirmaxx.git",
    "directory": "cli"
  },
  "keywords": [
    "quantis",
    "cli",
    "prediction-markets",
    "intel",
    "agents",
    "data"
  ],
  "license": "MIT",
  "scripts": {
    "build": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\" && tsc",
    "prepublishOnly": "npm run build",
    "start": "node dist/index.js",
    "dev": "tsc && node dist/index.js",
    "data": "tsc && node dist/index.js data"
  },
  "dependencies": {
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=18"
  }
}
